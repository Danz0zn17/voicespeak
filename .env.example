SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Voice engine: piper (default, offline), elevenlabs, or espeak
VOICE_ENGINE=piper
PIPER_BIN=piper
PIPER_MODEL=/home/pi/voice-speak/piper/en_US-lessac-medium.onnx

# Optional premium voice - only used if VOICE_ENGINE=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional: override the default input map
# INPUT_MAP_FILE=/home/pi/voice-speak-app/config/default_input_map.json
